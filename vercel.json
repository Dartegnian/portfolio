{
	"trailingSlash": false,
	"public": true,
	"name": "dartegnians-portfolio",
	"installCommand": "bun install",
	"framework": "angular",
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/api"
		}
	],
	"functions": {
		"api/index.mjs": {
			"includeFiles": "dist/dartegnians-portfolio/**"
		}
	}
}